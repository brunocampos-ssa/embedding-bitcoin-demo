# Mock mode is safe and is the default.
PAYMENT_PROVIDER=mock
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_PATH=./data/freedom-bounties.db
ALLOWED_ORIGIN=http://localhost:5173
MOCK_PAYMENT_FAILURE=

# Real mode requires a binary built with `-tags breez` and secure configuration.
BREEZ_API_KEY=
BREEZ_NETWORK=mainnet
BREEZ_STORAGE_DIR=./data/breez
# Demo-only secret transport. Never commit or log this value; prefer an external signer in production.
BREEZ_MNEMONIC=

MAX_PAYOUT_SATS=5000
MAX_FEE_SATS=500
MAX_DAILY_PAYOUT_SATS=20000
VITE_API_BASE_URL=
